<Window x:Class="Ds1ItemTracker.Views.FloatingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Ds1ItemTracker.Converters"
        xmlns:thumb="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="DS1 Tracker Overlay"
        Width="260" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MinWidth="140"
        Left="20" Top="20"
        Opacity="{Binding OverlayWindowOpacity}">

    <Window.Resources>
        <conv:DisplayStateToBrushConverter      x:Key="StateToBrush"/>
        <conv:DisplayStateToForegroundConverter x:Key="StateToFg"/>
        <conv:DisplayStateToStrikethroughConverter x:Key="StateToStrike"/>
    </Window.Resources>

    <!-- Outer border gives the dark card look -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1"
                Background="{Binding OverlayCardBackground}"
                BorderBrush="#80B8960C"
                BorderThickness="0,0,0,1"
                CornerRadius="3">

        <StackPanel>
            <!-- Total progress row — topmost -->
            <Border x:Name="TotalRow"
                    Background="#CC0D0D0D"
                    BorderBrush="#40B8960C"
                    BorderThickness="1,1,1,0"
                    CornerRadius="3,3,0,0"
                    Padding="8,4"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Total:"
                               Foreground="#FF888070"
                               FontSize="{Binding OverlayFontSize}"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding TotalProgress}"
                               Foreground="#FFB8960C" FontWeight="Bold"
                               FontSize="{Binding OverlayFontSize}"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Area header row — drag handle, pin, close -->
            <Border x:Name="HeaderRow"
                    Background="#AA141414"
                    BorderBrush="#40B8960C"
                    BorderThickness="1,0,1,0"
                    Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Area name + progress -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedArea.Name}"
                                   Foreground="#FFD4AC10"
                                   FontSize="{Binding OverlayFontSize}" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedArea.ProgressLabel}"
                                   Foreground="#FF888070"
                                   FontSize="{Binding OverlayFontSize}" Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Pin/unpin click-through toggle -->
                    <Button Grid.Column="1"
                            x:Name="BtnClickThrough"
                            Content="⊕" ToolTip="Toggle click-through"
                            FontSize="10" Padding="4,1" Margin="0,0,4,0"
                            Click="ClickThrough_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#FF888070" Cursor="Hand"/>

                    <!-- Close button -->
                    <Button Grid.Column="2"
                            Content="✕" ToolTip="Close overlay"
                            FontSize="10" Padding="4,1"
                            Click="Close_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#FF888070" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Item list -->
            <Border Background="{Binding OverlayCardBackground}"
                    BorderBrush="#40B8960C"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,3,3"
                    Padding="8,4,8,6">
                <ItemsControl ItemsSource="{Binding SelectedArea.Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding OverlayColumns}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}"
                                       Foreground="{Binding DataContext.OverlayFontBrush,
                                                   RelativeSource={RelativeSource AncestorType=Window}}"
                                       TextDecorations="{Binding DisplayState, Converter={StaticResource StateToStrike}}"
                                       FontSize="{Binding DataContext.OverlayFontSize,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Margin="0,1">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisplayState}" Value="2">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
        </Border>

        <!-- left-edge resize grip -->
        <thumb:Thumb Grid.Column="0"
                     Cursor="SizeWE"
                     DragDelta="ResizeLeftThumb_DragDelta">
            <thumb:Thumb.Template>
                <ControlTemplate TargetType="thumb:Thumb">
                    <Border Background="#18B8960C"
                            Width="8"
                            CornerRadius="0,3,3,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#55B8960C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </ControlTemplate>
            </thumb:Thumb.Template>
        </thumb:Thumb>

        <!-- Right-edge resize grip -->
        <thumb:Thumb Grid.Column="2"
                     Cursor="SizeWE"
                     DragDelta="ResizeThumb_DragDelta">
            <thumb:Thumb.Template>
                <ControlTemplate TargetType="thumb:Thumb">
                    <Border Background="#18B8960C"
                            Width="8"
                            CornerRadius="0,3,3,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#55B8960C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </ControlTemplate>
            </thumb:Thumb.Template>
        </thumb:Thumb>
    </Grid>
</Window>
