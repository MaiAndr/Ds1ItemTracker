<Window x:Class="Ds1ItemTracker.Views.FloatingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Ds1ItemTracker.Converters"
        Title="DS1 Tracker Overlay"
        Width="260" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Left="20" Top="20"
        Opacity="{Binding OverlayWindowOpacity}">

    <Window.Resources>
        <conv:DisplayStateToBrushConverter      x:Key="StateToBrush"/>
        <conv:DisplayStateToForegroundConverter x:Key="StateToFg"/>
        <conv:DisplayStateToStrikethroughConverter x:Key="StateToStrike"/>
    </Window.Resources>

    <!-- Outer border gives the dark card look -->
    <Border Background="{Binding OverlayCardBackground}"
            BorderBrush="#80B8960C"
            BorderThickness="0,0,0,1"
            CornerRadius="3">

        <StackPanel>
            <!-- Header row — stays interactive even in click-through mode -->
            <Border x:Name="HeaderRow"
                    Background="#CC0D0D0D"
                    BorderBrush="#40B8960C"
                    BorderThickness="1,1,1,0"
                    CornerRadius="3,3,0,0"
                    Padding="8,5"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Area name + progress -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedArea.Name}"
                                   Foreground="#FFD4AC10"
                                   FontSize="11" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedArea.ProgressLabel}"
                                   Foreground="#FF888070"
                                   FontSize="10" Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Pin/unpin click-through toggle -->
                    <Button Grid.Column="1"
                            x:Name="BtnClickThrough"
                            Content="⊕" ToolTip="Toggle click-through"
                            FontSize="10" Padding="4,1" Margin="0,0,4,0"
                            Click="ClickThrough_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#FF888070" Cursor="Hand"/>

                    <!-- Close button -->
                    <Button Grid.Column="2"
                            Content="✕" ToolTip="Close overlay"
                            FontSize="10" Padding="4,1"
                            Click="Close_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#FF888070" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Item list -->
            <Border Background="{Binding OverlayCardBackground}"
                    BorderBrush="#40B8960C"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,3,3"
                    Padding="8,4,8,6">
                <ItemsControl ItemsSource="{Binding SelectedArea.Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}"
                                           Foreground="{Binding DisplayState, Converter={StaticResource StateToFg}}"
                                           FontSize="9" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FullName}"
                                           Foreground="{Binding DisplayState, Converter={StaticResource StateToFg}}"
                                           TextDecorations="{Binding DisplayState, Converter={StaticResource StateToStrike}}"
                                           FontSize="11" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </Border>
</Window>
