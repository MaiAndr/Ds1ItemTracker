<Window x:Class="Ds1ItemTracker.Views.AddItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Item to Database"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#FFE0D5C0">

    <Window.Resources>
        <!-- Override system popup colors so the ComboBox dropdown has the dark theme -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"       Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"   Color="#FFE0D5C0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"    Color="#FFB8960C"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF111111"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"      Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"  Color="#FFE0D5C0"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FF888070"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="CaretBrush" Value="#FFB8960C"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FF1E1E1E"/>
                        <Setter Property="Foreground" Value="#FFE0D5C0"/>
                        <Setter Property="Padding" Value="6,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FFB8960C"/>
                                <Setter Property="Foreground" Value="#FF111111"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="#FFB8960C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
            <Setter Property="BorderBrush" Value="#FFB8960C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFB8960C"/>
                                <Setter Property="Foreground" Value="#FF111111"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="⚔ " Foreground="#FFB8960C" FontSize="16"/>
            <TextBlock Text="Add Item to Database" FontSize="15" FontWeight="Bold"
                       Foreground="#FFB8960C" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Flag ID (read-only) -->
        <StackPanel Grid.Row="2">
            <Label Content="Flag ID (read-only)"/>
            <TextBox x:Name="TxtFlagId" IsReadOnly="True" Foreground="#FFB8960C" FontFamily="Consolas"
                     FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <!-- Item Name -->
        <StackPanel Grid.Row="4">
            <Label Content="Item Name  *"/>
            <TextBox x:Name="TxtItemName" TextChanged="Validate"/>
        </StackPanel>

        <!-- Area -->
        <StackPanel Grid.Row="6">
            <Label Content="Area  *"/>
            <ComboBox x:Name="CmbArea" SelectionChanged="CmbArea_SelectionChanged"/>
        </StackPanel>

        <!-- New area name (hidden unless "New area…" selected) -->
        <StackPanel Grid.Row="8" x:Name="PanelNewArea" Visibility="Collapsed">
            <Label Content="New Area Name  *"/>
            <TextBox x:Name="TxtNewArea" TextChanged="Validate"/>
        </StackPanel>

        <!-- Notes -->
        <StackPanel Grid.Row="10">
            <Label Content="Notes (optional)"/>
            <TextBox x:Name="TxtNotes"/>
        </StackPanel>

        <!-- Validation error message -->
        <TextBlock Grid.Row="11" x:Name="TxtError"
                   Foreground="#FFC85A5A" FontSize="11" FontStyle="Italic"
                   Visibility="Collapsed" Margin="0,4,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="BtnAdd" Content="Add Item" IsEnabled="False" Click="Add_Click"
                    BorderBrush="#FFB8960C"/>
        </StackPanel>
    </Grid>
</Window>
