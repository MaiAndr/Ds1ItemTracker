<Window x:Class="Ds1ItemTracker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ Settings"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#FFE0D5C0">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FF888070"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFB8960C"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="CaretBrush" Value="#FFB8960C"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
            <Setter Property="BorderBrush" Value="#FFB8960C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFB8960C"/>
                                <Setter Property="Foreground" Value="#FF111111"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="⚙ " Foreground="#FFB8960C" FontSize="16"/>
            <TextBlock Text="Settings" FontSize="15" FontWeight="Bold"
                       Foreground="#FFB8960C" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Hotkeys section header -->
        <TextBlock Grid.Row="2"
                   Text="AREA NAVIGATION HOTKEYS"
                   Foreground="#FF888070"
                   FontSize="10" FontWeight="Bold"/>

        <!-- Hotkey capture fields -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Next area -->
            <StackPanel Grid.Column="0">
                <Label Content="Next area  →"/>
                <TextBox x:Name="TxtNext"
                         PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                         GotFocus="HotkeyBox_GotFocus"
                         LostFocus="HotkeyBox_LostFocus"
                         ToolTip="Click here then press any key combination"/>
                <TextBlock x:Name="TxtNextHint"
                           Text="Click to capture…"
                           Foreground="#FF555555" FontSize="10" Margin="2,3,0,0"/>
            </StackPanel>

            <!-- Prev area -->
            <StackPanel Grid.Column="2">
                <Label Content="← Previous area"/>
                <TextBox x:Name="TxtPrev"
                         PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                         GotFocus="HotkeyBox_GotFocus"
                         LostFocus="HotkeyBox_LostFocus"
                         ToolTip="Click here then press any key combination"/>
                <TextBlock x:Name="TxtPrevHint"
                           Text="Click to capture…"
                           Foreground="#FF555555" FontSize="10" Margin="2,3,0,0"/>
            </StackPanel>
        </Grid>

        <!-- OBS Overlay section header -->
        <TextBlock Grid.Row="6"
                   Text="OBS BROWSER OVERLAY"
                   Foreground="#FF888070"
                   FontSize="10" FontWeight="Bold"/>

        <!-- Port field -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="HTTP Port:"/>
            <TextBox x:Name="TxtPort"
                     IsReadOnly="False"
                     Cursor="IBeam"
                     Width="70"
                     ToolTip="Port the OBS overlay server listens on (default 7373). Requires restart of the overlay server."/>
            <TextBlock Text="  (restart required to take effect)"
                       Foreground="#FF555555" FontSize="10" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
