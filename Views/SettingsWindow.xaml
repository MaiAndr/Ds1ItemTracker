<Window x:Class="Ds1ItemTracker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ Settings"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#FFE0D5C0">

    <Window.Resources>
        <!-- Section label -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FF888070"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
        </Style>
        <!-- Read-only hotkey capture box -->
        <Style x:Key="HotkeyBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFB8960C"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="CaretBrush" Value="#FFB8960C"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
        <!-- Editable input box -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="CaretBrush" Value="#FFE0D5C0"/>
            <Setter Property="SelectionBrush" Value="#FFB8960C"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="IBeam"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFE0D5C0"/>
            <Setter Property="BorderBrush" Value="#FFB8960C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFB8960C"/>
                                <Setter Property="Foreground" Value="#FF111111"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#FFB8960C"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FF888070"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF1E1E1E"/>
                    <Setter Property="Foreground" Value="#FFB8960C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="⚙ " Foreground="#FFB8960C" FontSize="16"/>
            <TextBlock Text="Settings" FontSize="15" FontWeight="Bold"
                       Foreground="#FFB8960C" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="2">

            <!-- ── Tab 1: Overlay / Browser ── -->
            <TabItem Header="Overlay / Browser">
                <Grid Margin="0,16,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="OBS BROWSER OVERLAY"
                               Foreground="#FF888070"
                               FontSize="10" FontWeight="Bold"/>

                    <!-- Port -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="HTTP Port:" Width="160"/>
                        <TextBox x:Name="TxtPort"
                                 Style="{StaticResource InputBox}"
                                 Width="75"
                                 ToolTip="Port the OBS overlay server listens on (default 7373). Requires restart."/>
                        <TextBlock Text="  (restart required)"
                                   Foreground="#FF555555" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Font size -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="Font size:" Width="160"/>
                        <Slider x:Name="SliderFontSize"
                                Minimum="7" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True"
                                Width="130" VerticalAlignment="Center"
                                ValueChanged="SliderFontSize_ValueChanged"
                                ToolTip="Font size in px (7–32, default 11)"/>
                        <TextBlock x:Name="TxtFontSizeVal"
                                   Width="36" VerticalAlignment="Center"
                                   Foreground="#FFB8960C" TextAlignment="Right"/>
                    </StackPanel>

                    <!-- Font color -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Font color:"/>
                        <Border Grid.Column="1" x:Name="FontColorSwatch"
                                Width="24" Height="24" CornerRadius="3"
                                BorderBrush="#FF3A3A3A" BorderThickness="1"
                                VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="Pick color…"
                                HorizontalAlignment="Left" Padding="10,5"
                                Click="PickFontColor_Click"/>
                    </Grid>

                    <!-- Font opacity -->
                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Font opacity:"/>
                        <Slider Grid.Column="1" x:Name="SliderFontOpacity"
                                Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="SliderFontOpacity_ValueChanged"
                                ToolTip="Font opacity 0–100%"/>
                        <TextBlock Grid.Column="2" x:Name="TxtFontOpacityVal"
                                   VerticalAlignment="Center" TextAlignment="Right"
                                   Foreground="#FFB8960C"/>
                    </Grid>

                    <!-- Background color -->
                    <Grid Grid.Row="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Background color:"/>
                        <Border Grid.Column="1" x:Name="BgColorSwatch"
                                Width="24" Height="24" CornerRadius="3"
                                BorderBrush="#FF3A3A3A" BorderThickness="1"
                                VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="Pick color…"
                                HorizontalAlignment="Left" Padding="10,5"
                                Click="PickBgColor_Click"/>
                    </Grid>

                    <!-- Background opacity -->
                    <Grid Grid.Row="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Background opacity:"/>
                        <Slider Grid.Column="1" x:Name="SliderBgOpacity"
                                Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="SliderBgOpacity_ValueChanged"
                                ToolTip="Background opacity 0–100%"/>
                        <TextBlock Grid.Column="2" x:Name="TxtBgOpacityVal"
                                   VerticalAlignment="Center" TextAlignment="Right"
                                   Foreground="#FFB8960C"/>
                    </Grid>

                    <!-- Columns -->
                    <StackPanel Grid.Row="14" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="Columns:" Width="160"/>
                        <TextBox x:Name="TxtColumns"
                                 Style="{StaticResource InputBox}"
                                 Width="50"
                                 TextChanged="TxtColumns_TextChanged"
                                 ToolTip="Number of item columns in the overlay (1–8, default 1)"/>
                    </StackPanel>

                    <!-- Reset overlay to defaults -->
                    <Button Grid.Row="16" Content="Reset to defaults"
                            HorizontalAlignment="Left" Padding="10,4"
                            Foreground="#FF888070"
                            Click="ResetToDefaults_Click"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: Hotkeys ── -->
            <TabItem Header="Hotkeys">
                <Grid Margin="0,16,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="AREA NAVIGATION HOTKEYS"
                               Foreground="#FF888070"
                               FontSize="10" FontWeight="Bold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Prev area (left column) -->
                        <StackPanel Grid.Column="0">
                            <Label Content="← Previous area"/>
                            <TextBox x:Name="TxtPrev"
                                     Style="{StaticResource HotkeyBox}"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus"
                                     LostFocus="HotkeyBox_LostFocus"
                                     ToolTip="Click here then press any key combination"/>
                            <TextBlock x:Name="TxtPrevHint"
                                       Text="Click to capture…"
                                       Foreground="#FF555555" FontSize="10" Margin="2,3,0,0"/>
                        </StackPanel>

                        <!-- Next area (right column) -->
                        <StackPanel Grid.Column="2">
                            <Label Content="Next area  →"/>
                            <TextBox x:Name="TxtNext"
                                     Style="{StaticResource HotkeyBox}"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus"
                                     LostFocus="HotkeyBox_LostFocus"
                                     ToolTip="Click here then press any key combination"/>
                            <TextBlock x:Name="TxtNextHint"
                                       Text="Click to capture…"
                                       Foreground="#FF555555" FontSize="10" Margin="2,3,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Button Grid.Row="4" Content="Reset hotkeys to defaults"
                            HorizontalAlignment="Left" Padding="10,4"
                            Foreground="#FF888070"
                            Click="ResetHotkeys_Click"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Cancel" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
