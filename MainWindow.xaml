<Window x:Class="Ds1ItemTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Ds1ItemTracker.Converters"
        Title="DS1 Remastered — Item Pickup Tracker"
        Icon="app.ico"
        Width="1000" Height="640"
        MinWidth="1000" MinHeight="480"
        Background="{StaticResource BgDarkBrush}"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Window.Resources>
        <conv:DisplayStateToBrushConverter       x:Key="StateToBrush"/>
        <conv:DisplayStateToForegroundConverter  x:Key="StateToFg"/>
        <conv:DisplayStateToStrikethroughConverter x:Key="StateToStrike"/>
        <conv:BoolToConnectedConverter     x:Key="BoolToConnected"/>
        <conv:BoolToStatusBrushConverter   x:Key="BoolToStatusBrush"/>
        <conv:DoubleToPercentConverter     x:Key="DoubleToPct"/>
        <BooleanToVisibilityConverter      x:Key="DebugVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header bar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Title row -->
                <Grid Margin="12,8,12,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚔ " Foreground="{StaticResource AccentBrush}" FontSize="18"/>
                        <TextBlock Text="DARK SOULS REMASTERED" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="  Item Pickup Tracker" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnected}}"
                                   Foreground="{Binding IsConnected, Converter={StaticResource BoolToStatusBrush}}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Total: " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalProgress}"
                                   Foreground="{StaticResource AccentBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Overlay controls row -->
                <Grid Margin="12,0,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="⬡ Overlay  Opacity:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding OverlayBgOpacity, StringFormat={}{0}%}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="10" Width="30" VerticalAlignment="Center"/>
                    <Slider Grid.Column="2" Minimum="0" Maximum="100"
                            Value="{Binding OverlayBgOpacity}"
                            VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <Button Grid.Column="3" Content="⧉ Float" Padding="10,2"
                            ToolTip="Toggle always-on-top floating overlay (for windowed/borderless fullscreen)"
                            Click="FloatOverlay_Click" Margin="0,0,10,0"/>

                    <TextBlock Grid.Column="4"
                               Text="{Binding OverlayUrl}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="10" VerticalAlignment="Center" Cursor="Hand"
                               ToolTip="Click to open overlay in browser. Use as OBS Browser Source."
                               MouseLeftButtonDown="OverlayUrl_Click"/>

                    <!-- Randomizer controls -->
                    <Border Grid.Column="5" Width="1" Height="14" Background="#FF3A3A3A" Margin="8,0"/>
                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                        <TextBlock Text="🎲" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                   ToolTip="Item Randomizer"/>
                        <TextBlock Text="{Binding RandomizerStatusText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding GameFolder, UpdateSourceTrigger=LostFocus}"
                                 Width="180" FontSize="10" VerticalContentAlignment="Center"
                                 ToolTip="DS1R game folder — seed subfolders are detected automatically"
                                 Padding="4,1" Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding ParamFileLabel}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                   MaxWidth="180" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding LatestParamFile}"/>
                        <Button Content="⟳" Padding="6,2" Margin="0,0,4,0"
                                ToolTip="Refresh: scan for a newer randomizer seed folder"
                                Click="RefreshParam_Click"/>
                        <Button Content="Apply" Padding="8,2" Margin="0,0,4,0"
                                IsEnabled="{Binding CanApplyRandomizer}"
                                ToolTip="Remap item flag IDs using the detected randomizer seed"
                                Click="ApplyRandomizer_Click"/>
                        <Button Content="Revert" Padding="8,2"
                                IsEnabled="{Binding RandomizerActive}"
                                ToolTip="Restore the original items.json"
                                Click="RevertRandomizer_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Main content ────────────────────────────────────────────────── -->
        <TabControl Grid.Row="1" Margin="8">

            <!-- ── Tab 1: Item Tracker ────────────────────────────────────── -->
            <TabItem Header="  Item Tracker  ">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" MinWidth="150"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Area list -->
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" Text="AREAS"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="Bold" Margin="6,6,6,4"/>
                        <ListBox ItemsSource="{Binding Areas}"
                                 SelectedItem="{Binding SelectedArea}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ProgressLabel}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BorderBrush2}"/>

                    <!-- Item list -->
                    <DockPanel Grid.Column="2">
                        <!-- Area header -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource BgMidBrush}"
                                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1"
                                Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SelectedArea.Name}" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedArea.ProgressLabel}"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedArea.ProgressPercent, Converter={StaticResource DoubleToPct}}"
                                               Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Items -->
                        <ListView ItemsSource="{Binding SelectedArea.Items}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  BorderThickness="0">
                            <ListView.Resources>
                                <ContextMenu x:Key="ItemContextMenu" Background="#FF2A2A2A"
                                             BorderBrush="#FF3A3A3A" Foreground="#FFE0D5C0">
                                    <MenuItem Header="✓  Mark as Verified" FontFamily="Segoe UI"
                                              Click="MarkVerified_Click"
                                              Foreground="#FFB8960C"/>
                                    <Separator Background="#FF3A3A3A"/>
                                    <MenuItem Header="🗑  Remove from list" FontFamily="Segoe UI"
                                              Click="RemoveItem_Click"
                                              Foreground="#FFC85A5A"/>
                                </ContextMenu>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding DisplayState, Converter={StaticResource StateToBrush}}"
                                            CornerRadius="2" Margin="2,1" Padding="10,6"
                                            ToolTip="{Binding TooltipText}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon -->
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       Foreground="{Binding DisplayState, Converter={StaticResource StateToFg}}"
                                                       FontSize="14" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Item name -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding FullName}"
                                                       Foreground="{Binding DisplayState, Converter={StaticResource StateToFg}}"
                                                       TextDecorations="{Binding DisplayState, Converter={StaticResource StateToStrike}}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                            <!-- Flag ID (small) -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FlagId}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: Flag Scanner (debug builds only) ───────────────── -->
            <TabItem Header="  Flag Scanner  "
                     Visibility="{Binding IsDebugBuild, Converter={StaticResource DebugVisConverter}}">
                <DockPanel Margin="8">
                    <!-- Description -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource BgLightBrush}"
                            BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                            <Run FontWeight="Bold" Foreground="{StaticResource AccentBrush}">How to use:</Run>
                            <Run>  1. Load your save in-game so you are in the world.&#x0a;</Run>
                            <Run>  2. Click </Run><Run FontWeight="Bold">Take Snapshot</Run><Run> to record current flag state.&#x0a;</Run>
                            <Run>  3. Pick up an item in-game.&#x0a;</Run>
                            <Run>  4. Click </Run><Run FontWeight="Bold">Detect Changes</Run><Run> — newly set flags are shown below.&#x0a;</Run>
                            <Run>  5. Copy the Flag ID and add it to </Run><Run FontWeight="Bold">items.json</Run><Run>.</Run>
                        </TextBlock>
                    </Border>

                    <!-- Toolbar -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="📷  Take Snapshot" Padding="14,7" Margin="0,0,8,0"
                                Click="TakeSnapshot_Click"/>
                        <Button Content="🔍  Detect Changes" Padding="14,7" Margin="0,0,8,0"
                                IsEnabled="{Binding CanDetect}" Click="DetectChanges_Click"/>
                        <Button Content="🗑  Clear" Padding="14,7" Margin="0,0,8,0" Click="ClearChanges_Click"/>
                        <Button Content="🔧  Diagnostics" Padding="14,7" Click="Diagnostics_Click"
                                ToolTip="Show pointer-chain diagnostic info to help debug memory read failures"/>
                    </StackPanel>

                    <!-- Status message -->
                    <TextBlock DockPanel.Dock="Top" Text="{Binding ScannerStatus}"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"
                               TextWrapping="Wrap" FontStyle="Italic"/>

                    <!-- Results header -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FLAG ID" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="10,0"/>
                        <TextBlock Grid.Column="1" Text="ACTION" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                    <Separator DockPanel.Dock="Top" Margin="0,0,0,2"/>

                    <!-- Results list -->
                    <ListView ItemsSource="{Binding DetectedChanges}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FlagId}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold" FontFamily="Consolas" FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="newly SET"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="Add to DB" Padding="8,3" Margin="0,0,4,0"
                                                Tag="{Binding FlagId}"
                                                Click="AddToDatabase_Click"/>
                                        <Button Content="Copy ID" Padding="8,3"
                                                Tag="{Binding FlagId}"
                                                Click="CopyFlagId_Click"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- ── Status bar ───────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="⟳ Reconnect" Padding="10,2" Margin="8,0"
                        ToolTip="Force-disconnect and reconnect to DarkSoulsRemastered.exe"
                        Click="Reconnect_Click"/>
                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Last updated: "/>
                    <Run Text="{Binding LastUpdate, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
